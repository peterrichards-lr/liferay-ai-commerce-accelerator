# Liferay Connection Configuration
# Target Liferay instance URL (e.g., http://localhost:8080 or https://aica-e2e.local)
LIFERAY_API_URL=

# Liferay API Credentials (Basic Authentication)
# Used by the microservice and setup scripts to perform administrative bootstrap operations,
# such as auto-provisioning catalogs/channels and verifying DXP settings.
# Typically a portal administrator account (e.g., test@liferay.com).
LIFERAY_API_USERNAME=
LIFERAY_API_PASSWORD=

# Liferay OAuth2 Application Credentials for the microservice (Client Credentials Flow)
# Generated dynamically inside Liferay (under Control Panel -> Client Extensions)
# for the Microservice Headless Server. Used at runtime to authenticate secure Headless API calls.
# Note: Leaving these blank during local development will force the microservice to fall back
# to the administrator Basic Auth credentials above.
LIFERAY_OAUTH_CLIENT_ID=
LIFERAY_OAUTH_CLIENT_SECRET=

# AI Provider Configuration
# Supported providers: openai, gemini, anthropic
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Override the primary AI key (generic fallback)
# AI_API_KEY=

# Optional: Dedicated key for AI Media (Images/PDFs)
# AI_MEDIA_API_KEY=
