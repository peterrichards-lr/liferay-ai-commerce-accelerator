# Liferay Connection Configuration
# Liferay instance URL (e.g., http://localhost:8080 or https://your-liferay.com)
LIFERAY_API_URL=

# Liferay API credentials
LIFERAY_API_USERNAME=
LIFERAY_API_PASSWORD=

# Liferay OAuth2 application credentials for the microservice
LIFERAY_OAUTH_CLIENT_ID=
LIFERAY_OAUTH_CLIENT_SECRET=

# AI Provider Configuration
# Supported providers: openai, gemini, anthropic
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Override the primary AI key (generic fallback)
# AI_API_KEY=

# Optional: Dedicated key for AI Media (Images/PDFs)
# AI_MEDIA_API_KEY=
