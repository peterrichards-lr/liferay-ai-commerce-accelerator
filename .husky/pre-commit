# Load NVM if it exists so GUI clients (like GitHub Desktop) can find Node and Yarn
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Load local huskyrc if it exists for user-specific PATH overrides
[ -f ~/.huskyrc ] && . ~/.huskyrc

echo "🔍 Running pre-commit checks..."

echo "⚡ Running lint-staged (auto-fixing)..."
npx lint-staged || exit 1

echo "🧹 Running full project lint..."
yarn lint || exit 1

echo "🧪 Running unit tests..."
yarn test || exit 1

echo "✅ Pre-commit checks passed!"