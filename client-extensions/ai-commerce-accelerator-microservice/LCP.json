{
  "id": "ai-commerce-accelerator-microservice",
  "kind": "Deployment",
  "memory": 1024,
  "cpu": 1,
  "scale": 1,
  "ports": [
    {
      "port": 3001,
      "external": true
    }
  ],
  "livenessProbe": {
    "httpGet": {
      "path": "/api/v1/health",
      "port": 3001
    }
  },
  "readinessProbe": {
    "httpGet": {
      "path": "/api/v1/health",
      "port": 3001
    }
  },
  "env": {
    "PORT": "3001",
    "NODE_ENV": "production"
  },
  "loadBalancer": {
    "targetPort": 3001
  }
}
