{
  "id": "aicommerceacceleratormicroservice",
  "kind": "Deployment",
  "memory": 1024,
  "cpu": 1,
  "scale": 1,
  "livenessProbe": {
    "httpGet": {
      "path": "/api/v1/health",
      "port": 3001
    }
  },
  "readinessProbe": {
    "httpGet": {
      "path": "/api/v1/health",
      "port": 3001
    }
  },
  "env": {
    "PORT": "3001",
    "NODE_ENV": "production"
  }
}
