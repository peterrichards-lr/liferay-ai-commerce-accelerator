{
  "allow.list": [
    "http://localhost:5173",
    "http://localhost:3000",
    "http://localhost:3001",
    "http://localhost:8080",
    "https://aica-e2e.local"
  ],
  "com.liferay.lxc.dxp.server.protocol": "http",
  "config.node.config.trees": [
    "${LIFERAY_ROUTES_CLIENT_EXTENSION}",
    "${LIFERAY_ROUTES_DXP}"
  ],
  "ai-commerce-accelerator-microservice.oauth2.authorization.uri": "/o/oauth2/authorize",
  "ai-commerce-accelerator-microservice.oauth2.headless.server.scopes": [
    "Liferay.Headless.Admin.User.everything",
    "Liferay.Headless.Batch.Engine.everything",
    "Liferay.Headless.Admin.Address.everything",
    "Liferay.Headless.Commerce.Admin.Catalog.everything",
    "Liferay.Headless.Commerce.Admin.Channel.everything",
    "Liferay.Headless.Commerce.Admin.Inventory.everything",
    "Liferay.Headless.Commerce.Admin.Order.everything",
    "Liferay.Headless.Commerce.Admin.Pricing.everything",
    "Liferay.Headless.Delivery.everything",
    "C_AICAConfiguration.everything"
  ],
  "ai-commerce-accelerator-microservice.oauth2.introspection.uri": "/o/oauth2/introspect",
  "ai-commerce-accelerator-microservice.oauth2.jwks.uri": "/o/oauth2/jwks",
  "ai-commerce-accelerator-microservice.oauth2.redirect.uris": "/o/oauth2/redirect",
  "ai-commerce-accelerator-microservice.oauth2.token.uri": "/o/oauth2/token",
  "liferay.oauth.application.external.reference.codes": [
    "ai-commerce-accelerator-microservice"
  ],
  "logger.level": "trace",
  "logger.pretty": true,
  "main.liferay.server.oauth.application": "ai-commerce-accelerator-microservice",
  "server.port": 3001,
  "token.check.exclude.list": []
}
