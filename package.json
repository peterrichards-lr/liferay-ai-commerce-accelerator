{
  "private": true,
  "bin": {
    "aica": "./scripts/aica-cli.cjs"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": {
    "packages": [
      "client-extensions/ai-commerce-accelerator-microservice",
      "client-extensions/liferay-accelerator-sdk",
      "client-extensions/ai-commerce-accelerator-configuration",
      "client-extensions/ai-commerce-accelerator-frontend"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "baseline-browser-mapping": "^2.10.37",
    "happy-dom": "^20.10.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.4",
    "yaml": "^2.9.0"
  },
  "resolutions": {
    "codemirror": "6.0.2",
    "uuid": "^11.1.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.62.0",
    "@rollup/rollup-darwin-x64": "4.62.0",
    "@rollup/rollup-linux-x64-gnu": "4.62.0"
  },
  "scripts": {
    "prepare": "husky || true",
    "test": "FORCE_COLOR=0 yarn workspaces run test",
    "smoke": "playwright test --config playwright/playwright.config.js",
    "verify": "node scripts/test-e2e-orchestrator.js",
    "verification": "playwright test --config playwright/playwright-e2e.config.js",
    "preflight": "node scripts/preflight.mjs",
    "ldm:init": "yarn preflight && bash scripts/run-e2e-ldm.sh --init-only -k",
    "ldm:init-from": "ldm init-from . aica --db postgresql --no-captcha --fast-login --feature LPD-35443 --sidecar --host-name aica-e2e.local --build",
    "ldm:monitor": "ldm monitor . -p aica",
    "lint": "yarn workspaces run lint && yarn lint:md && yarn lint:cx",
    "verify:all": "npm run lint && npm test && bash scripts/run-e2e-ldm.sh -v -k",
    "verify:live": "node scripts/verify-live-ai.mjs",
    "lint:md": "markdownlint '**/*.md' --ignore '**/node_modules/**' --ignore '**/build/**' --ignore '**/bundles/**' --ignore '**/aica/**' --ignore 'GETTING_STARTED.md'",
    "lint:cx": "node scripts/validate-cx.js",
    "update-browser-data": "yarn add -D baseline-browser-mapping@latest -W && npx update-browserslist-db@latest -y"
  },
  "lint-staged": {
    "client-extensions/ai-commerce-accelerator-microservice/**/*.{js,cjs}": [
      "eslint --fix --config client-extensions/ai-commerce-accelerator-microservice/eslint.config.mjs",
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-microservice/**/*.json": [
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-microservice/**/*.md": [
      "prettier --write",
      "markdownlint"
    ],
    "client-extensions/ai-commerce-accelerator-configuration/**/*.{js,jsx}": [
      "eslint --fix --config client-extensions/ai-commerce-accelerator-configuration/eslint.config.js",
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-configuration/**/*.json": [
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-configuration/**/*.md": [
      "prettier --write",
      "markdownlint"
    ],
    "client-extensions/ai-commerce-accelerator-frontend/**/*.{js,jsx}": [
      "eslint --fix --config client-extensions/ai-commerce-accelerator-frontend/eslint.config.js",
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-frontend/**/*.json": [
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-frontend/**/*.md": [
      "prettier --write",
      "markdownlint"
    ],
    "*.{js,json,yaml,yml}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint"
    ]
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-react": "6.0.2",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "12.10.0",
    "codemirror": "6.0.2",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "immutable": "5.1.6",
    "jsdom": "^29.1.1",
    "openai": "6.42.0",
    "react-codemirror2": "9.0.1",
    "rollup": "4.62.0",
    "vite": "8.0.16"
  }
}
