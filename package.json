{
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": {
    "packages": [
      "aica-e2e/client-extensions/ai-commerce-accelerator-microservice",
      "client-extensions/ai-commerce-accelerator-microservice",
      "client-extensions/liferay-accelerator-sdk",
      "client-extensions/ai-commerce-accelerator-configuration",
      "client-extensions/ai-commerce-accelerator-frontend"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "baseline-browser-mapping": "^2.10.31",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3"
  },
  "resolutions": {
    "whatwg-url": "5.0.0",
    "html-encoding-sniffer": "2.0.1",
    "fast-xml-parser": "^5.5.6",
    "path-to-regexp": "^6.3.0",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.6",
    "micromatch": "^4.0.8",
    "ws": "^8.18.0",
    "uuid": "11.1.1",
    "msw": "2.4.0",
    "vite": "8.0.14",
    "axios": "^1.15.1",
    "tough-cookie": "^4.1.4",
    "cookie": "^0.7.2",
    "smol-toml": "^1.3.1",
    "markdown-it": "^14.1.0",
    "follow-redirects": "^1.15.6",
    "picomatch": "^4.0.2",
    "glob": "^10.5.0",
    "elliptic": "^6.6.1",
    "@tootallnate/once": "^3.0.1",
    "fast-uri": "3.1.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.4",
    "@rollup/rollup-darwin-x64": "4.60.4",
    "@rollup/rollup-linux-x64-gnu": "4.60.4"
  },
  "scripts": {
    "prepare": "husky || true",
    "test": "FORCE_COLOR=0 yarn workspaces run test",
    "smoke": "playwright test --config playwright/playwright.config.js",
    "verify": "node scripts/test-e2e-orchestrator.js",
    "verification": "playwright test --config playwright/playwright-e2e.config.js",
    "lint": "yarn workspaces run lint && yarn lint:md",
    "lint:md": "markdownlint '**/*.md' --ignore '**/node_modules/**' --ignore '**/build/**' --ignore '**/bundles/**' --ignore 'GETTING_STARTED.md'",
    "update-browser-data": "yarn add -D baseline-browser-mapping@latest -W && npx update-browserslist-db@latest -y"
  },
  "lint-staged": {
    "client-extensions/ai-commerce-accelerator-microservice/**/*.{js,cjs}": [
      "eslint --fix --config client-extensions/ai-commerce-accelerator-microservice/eslint.config.mjs",
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-microservice/**/*.json": [
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-microservice/**/*.md": [
      "prettier --write",
      "markdownlint"
    ],
    "client-extensions/ai-commerce-accelerator-configuration/**/*.{js,jsx}": [
      "eslint --fix --config client-extensions/ai-commerce-accelerator-configuration/eslint.config.js",
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-configuration/**/*.json": [
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-configuration/**/*.md": [
      "prettier --write",
      "markdownlint"
    ],
    "client-extensions/ai-commerce-accelerator-frontend/**/*.{js,jsx}": [
      "eslint --fix --config client-extensions/ai-commerce-accelerator-frontend/eslint.config.js",
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-frontend/**/*.json": [
      "prettier --write"
    ],
    "client-extensions/ai-commerce-accelerator-frontend/**/*.md": [
      "prettier --write",
      "markdownlint"
    ],
    "*.{js,json,yaml,yml}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint"
    ]
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "@vitejs/plugin-react": "6.0.2",
    "ajv-formats": "3.0.1",
    "better-sqlite3": "12.10.0",
    "esbuild": "0.28.0",
    "eslint": "10.4.0",
    "immutable": "5.1.5",
    "jsdom": "^29.1.1",
    "openai": "6.39.0",
    "react-codemirror2": "9.0.1",
    "rollup": "4.60.4",
    "vite": "8.0.14"
  }
}
